# Server Configuration Example
# Copy this file to .env (development) or .env.production (production) and fill in your values

# ==================== Server Configuration ====================
# Server port
SERVER_PORT=3000

# API route prefix
API_PREFIX=/api

# Session secret key (use a strong random string)
SESSION_SECRET=your-session-secret-key-change-this

# JWT secret key (use a strong random string)
JWT_SECRET=your-jwt-secret-key-change-this

# ==================== MySQL Database Configuration ====================
# Database host
DB_HOST=localhost

# Database port
DB_PORT=3306

# Database name
DB_NAME=your_database_name

# Database username
DB_USER=root

# Database password
DB_PWD=your_database_password

# ==================== Redis Configuration ====================
# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis username (Redis 6+ ACL, use 'default' if not set)
REDIS_USER=default

# Redis password
REDIS_PWD=your_redis_password

# Redis database number (0-15)
REDIS_DB=0

# ==================== WebSocket Configuration ====================
# WebSocket path
WS_PATH=/ws

# WebSocket port
WS_PORT=3001

# WebSocket authentication token (use a strong random string)
WS_AUTH_TOKEN=your-websocket-auth-token-change-this
